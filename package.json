{
  "name": "mwm",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "MWM_CLIENT",
    "MWM_ADMIN"
  ],
  "scripts": {
    "dev:client": "npm --prefix MWM_CLIENT run dev",
    "dev:admin": "npm --prefix MWM_ADMIN run dev",
    "build:client": "npm --prefix MWM_CLIENT run build",
    "build:admin": "npm --prefix MWM_ADMIN run build",
    "build": "npm run build:client && npm run build:admin",
    "lint:client": "npm --prefix MWM_CLIENT run lint",
    "lint:admin": "npm --prefix MWM_ADMIN run lint",
    "lint": "npm run lint:client && npm run lint:admin"
  }
}
