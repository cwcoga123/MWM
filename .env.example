# Public browser-safe values from Supabase > Project Settings > API.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Local development only. This flag is ignored in production builds.
VITE_DEV_AUTH_BYPASS=false

# Free key from https://fred.stlouisfed.org/docs/api/api_key.html. Used only by
# scripts/fetch-fred-data.mjs (Node). Never prefix this with VITE_.
FRED_API_KEY=your-fred-api-key
